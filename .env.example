# Optional for web app: used by mock mode, WalletConnect transport, and test-wallet login mode.
VITE_RPC_URL=http://127.0.0.1:8545
VITE_CHAIN_ID=31337
VITE_VOTING_CONTRACT=0x0000000000000000000000000000000000000000
# Required in browser mode: WalletConnect project id for Rainbow/WalletConnect connectors.
VITE_WALLETCONNECT_PROJECT_ID=
# Optional: approximate block time in seconds for proposal date->block hints in UI.
VITE_BLOCK_TIME_SECONDS=12
# Optional: enable full in-UI mock wallet+contracts mode (default false).
VITE_USE_MOCK=false
# Optional: deterministic local wallet for e2e front flows.
VITE_TEST_PRIVATE_KEY=
# Optional: show private-key login controls in UI (default hidden).
VITE_ENABLE_TEST_WALLET_LOGIN=false
CLI_RPC_URL=http://127.0.0.1:8545
CLI_CONTRACT=0x0000000000000000000000000000000000000000

# Contracts deploy (hardhat-deploy)
# Single EOA key used as deployer and VotingCore owner.
DEPLOYER_PRIVATE_KEY=
POLYGON_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
# Optional verification API key (Etherscan API v2, single key for supported chains)
ETHERSCAN_API_KEY=
# Backward-compatible fallbacks (deprecated; prefer ETHERSCAN_API_KEY)
POLYGONSCAN_API_KEY=
ARBISCAN_API_KEY=
